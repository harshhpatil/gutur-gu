# Example environment variables for local development
PORT=3000
SERVER_URL=http://localhost:3000
MONGO_URI=mongodb://127.0.0.1:27017/gutur-gu
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173
REDIS_URL=redis://127.0.0.1:6379
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
NODE_ENV=development
DEFAULT_TIMEZONE=Asia/Kolkata

# Notes:
# - Set real values in a local .env (do NOT commit secrets to version control).
# - Ensure MongoDB is running locally or provide a valid hosted URI.
# - Set REDIS_URL when running multiple backend containers or Socket.IO in production.
